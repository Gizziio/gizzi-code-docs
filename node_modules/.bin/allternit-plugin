#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/plugin-sdk/bin/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/plugin-sdk/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/node_modules:/Users/macbook/Desktop/allternit-workspace/node_modules:/Users/macbook/Desktop/node_modules:/Users/macbook/node_modules:/Users/node_modules:/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/plugin-sdk/bin/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/plugin-sdk/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/@allternit/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/packages/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/node_modules:/Users/macbook/Desktop/allternit-workspace/node_modules:/Users/macbook/Desktop/node_modules:/Users/macbook/node_modules:/Users/node_modules:/node_modules:/Users/macbook/Desktop/allternit-workspace/allternit/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@allternit/plugin-sdk/bin/allternit-plugin.js" "$@"
else
  exec node  "$basedir/../@allternit/plugin-sdk/bin/allternit-plugin.js" "$@"
fi
